# QuantTradingOS MCP Server — base URLs and compliance policy DB.
# Copy to .env or set in environment. Never commit .env.

# Orchestrator API (pipeline, backtest, decision)
ORCHESTRATOR_URL=http://localhost:8000

# Data service API (prices, news, insider)
DATA_SERVICE_URL=http://localhost:8001

# Supabase / Database (pgvector for policy retrieval and skill nodes)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI API key for embedding queries (text-embedding-3-small) when retrieving policies
OPENAI_API_KEY=

# Hard-Limit circuit breaker (execute_trade): exposure and p90 vol limits
# MCP_MAX_SINGLE_ORDER_NOTIONAL=500000
# MCP_MAX_NOTIONAL_PER_NAME=2000000
# MCP_MAX_TOTAL_ABSOLUTE_NOTIONAL=25000000
# MCP_MAX_VOL_SCALED_NOTIONAL=50000
# p90 daily vol: JSON per symbol and/or default for all
# MCP_P90_VOL_JSON={"AAPL":0.012,"MSFT":0.011}
# MCP_P90_VOL_DEFAULT=0.01

# Enterprise logging (JSONL for ML-ready pipelines)
# MCP_LOG_EPHEMERAL_PATH=/var/log/qtos/ephemeral.jsonl
# MCP_LOG_EVENTS_PATH=/var/log/qtos/events.jsonl
