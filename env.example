# QuantTradingOS Data Ingestion Service — copy to .env and set values. Never commit .env.

# Supabase / Database
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Finnhub (news, insider transactions)
FINNHUB_API_KEY=your_finnhub_api_key

# Symbols to track (comma-separated)
TRACKED_SYMBOLS=AAPL,MSFT,NVDA,TSLA,SPY,QQQ

# Scheduler intervals (seconds)
PRICE_INTERVAL_SECONDS=3600
NEWS_INTERVAL_SECONDS=1800
INSIDER_INTERVAL_SECONDS=21600
